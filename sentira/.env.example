# ==========================================================================
# Sentira — environment configuration
# ==========================================================================
# Copy to `.env` and fill in. EVERY field is optional for local dev:
# the system boots in "stub mode" (in-memory store, logged-not-sent alerts,
# mock RuView data) when the real credentials are absent.
#
# ⚠️  This is a SUPPLEMENTAL alert layer, not a medical device. Every alert
# is phrased "possible <event> detected — please check on [name]".
#
# Deploy modes:
#   docker compose up -d           everything in containers (Pi prod)
#   docker compose up -d mosquitto  + pnpm dev    (dev on host machine)
#   pnpm dev                       all on host machine (no Docker)
# ==========================================================================

# --- MQTT (the local message bus; RuView nodes publish here) -------------
# Docker: middleware reaches mosquitto via service name
# Dev on host: use 127.0.0.1
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_DISCOVERY_PREFIX=homeassistant
RUVIEW_NODE_PREFIX=wifi_densepose

# --- Middleware API -------------------------------------------------------
MIDDLEWARE_PORT=4400
# Set a random token to secure dashboard<->middleware comms on your LAN
MIDDLEWARE_API_TOKEN=

# --- Alerting providers (optional; stubbed when absent) -------------------
# Twilio — one vendor for SMS + WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=          # E.164, e.g. +15551234567
TWILIO_WHATSAPP_FROM=        # e.g. whatsapp:+14155238886

# Firebase Cloud Messaging (push). Path to service-account JSON.
FCM_SERVICE_ACCOUNT_PATH=

# --- Caregiver dashboard (Next.js) ---------------------------------------
# These are empty for stub auth. Sets a mock caregiver login.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Docker: dashboard reaches middleware via service name
# Dev: http://<pi-lan-ip>:4400 or http://127.0.0.1:4400
NEXT_PUBLIC_MIDDLEWARE_URL=http://middleware:4400

# --- Detection thresholds (defaults baked in code; override here) --------
FALL_CONFIRM_WINDOW_SECONDS=20
INACTIVITY_DAY_SECONDS=7200      # 2h
INACTIVITY_NIGHT_SECONDS=28800   # 8h
HEARTBEAT_TIMEOUT_SECONDS=90      # node silent → "sensor offline" alert
ESCALATION_TIMEOUT_SECONDS=180    # unacked HIGH → re-notify + secondary

# --- Misc -----------------------------------------------------------------
LOG_LEVEL=info
TZ=UTC

    "lint": "echo 'no lint'"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@sentira/types": "workspace:*",
    "fastify": "^5.1.0",
    "mqtt": "^5.10.1",
    "nanoid": "^5.0.7",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "aedes": "^1.1.1",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }

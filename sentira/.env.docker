# Docker compose mode — service names, not host loopback
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_DISCOVERY_PREFIX=homeassistant
RUVIEW_NODE_PREFIX=wifi_densepose

MIDDLEWARE_PORT=4400
MIDDLEWARE_API_TOKEN=

NEXT_PUBLIC_MIDDLEWARE_URL=http://middleware:4400
NEXT_PUBLIC_MIDDLEWARE_API_TOKEN=

FALL_CONFIRM_WINDOW_SECONDS=20
INACTIVITY_DAY_SECONDS=7200
INACTIVITY_NIGHT_SECONDS=28800
HEARTBEAT_TIMEOUT_SECONDS=90
ESCALATION_TIMEOUT_SECONDS=180

LOG_LEVEL=info
TZ=UTC
